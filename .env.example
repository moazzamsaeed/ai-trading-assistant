# Copy this file to .env and fill in real values. .env is gitignored.

# ---- Trading mode ----
TRADING_MODE=paper                  # paper | live
ACCOUNT_TYPE=cash                   # MUST be 'cash'. Margin is forbidden.

# ---- Hard risk limits (enforced by Hermes in code) ----
DAILY_LOSS_LIMIT_USD=500
MAX_POSITION_SIZE_USD=2000
MAX_CONCURRENT_POSITIONS=5
MAX_OPTIONS_CONTRACTS_PER_TRADE=5

# ---- LLM spend cap (soft) ----
# Router warns at 80% of cap, refuses non-essential calls at 100%.
# Critical paths (kill-switch, halt reasoning) can bypass via bypass_budget=True.
MONTHLY_LLM_BUDGET_USD=100

# ---- Alpaca ----
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ---- LLM providers ----
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# ---- Discord ----
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ALERTS=
DISCORD_CHANNEL_RESEARCH=
DISCORD_CHANNEL_TRADES=
DISCORD_CHANNEL_LOGS=
DISCORD_CHANNEL_COMMANDS=

# ---- Database ----
DATABASE_URL=sqlite:///data/traderouter.db

# ---- Logging ----
LOG_LEVEL=INFO
